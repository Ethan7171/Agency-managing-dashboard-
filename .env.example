# ---- Required ----
DATABASE_URL=postgres://user:pass@host:5432/flax_occ
# 64 hex chars (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=
# Password for the single internal Flax login
ADMIN_PASSWORD=
# Public base URL of the deployed app (used to build webhook URLs shown in Settings)
APP_BASE_URL=https://your-app.up.railway.app

# ---- Close (down-funnel truth) ----
CLOSE_API_KEY=
# Name of the Close custom field holding the agency code on leads/opportunities
CLOSE_AGENCY_FIELD=outbound_agency

# ---- Slack (either a bot token, or a single incoming webhook) ----
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
# Fallback channel for portfolio digests if an agency has no channel set
SLACK_DEFAULT_CHANNEL=

# ---- AI reply classifier (optional, cost-capped) ----
ANTHROPIC_API_KEY=
CLASSIFIER_DAILY_CAP=500
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ---- Behavior ----
# true = skip live platform syncs for connections marked demo; seeded data only
DEMO_MODE=false
BACKFILL_DAYS=60
SYNC_CRON=*/30 * * * *
PORT=3000
